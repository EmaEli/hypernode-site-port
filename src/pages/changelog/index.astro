---
import ChangelogPage from '../../components/pages-view/changelog/ChangelogPage.astro'
import { getChangelogEntries } from '../../lib/strapi'
import BaseLayout from '../../layouts/BaseLayout.astro'

const changelogEntries = await getChangelogEntries()
---

<BaseLayout
  seo={{
    title: 'Changelog | Hypernode',
    description: 'Latest platform releases, product updates, and deployment improvements from Hypernode.',
    canonical: 'https://www.hypernode.com/changelog/',
    hreflang: [
      { lang: 'en', href: 'https://www.hypernode.com/changelog/' },
      { lang: 'nl', href: 'https://www.hypernode.com/nl/changelog/' },
    ],
  }}
>
  <ChangelogPage entries={changelogEntries} />
</BaseLayout>