---
import { getEntry } from 'astro:content'
import PricingPage from '../../../components/pages-view/pricing/PricingPage.astro'
import BaseLayout from '../../../layouts/BaseLayout.astro'

const entry = await getEntry('pricing', 'content')

if (!entry) {
  throw new Error('Pricing content entry not found: src/content/pricing/content.mdx')
}

const { seo } = entry.data
---

<BaseLayout
  seo={{
    title: seo.title,
    description: seo.description,
    canonical: 'https://www.hypernode.com/en/plans-and-prices/',
    ogImage: 'https://www.hypernode.com/wp-content/uploads/2023/09/Hypernode-OG-image.jpg',
    hreflang: [
      { lang: 'en', href: 'https://www.hypernode.com/en/plans-and-prices/' },
      { lang: 'nl', href: 'https://www.hypernode.com/nl/pakketten-en-prijzen/' },
      { lang: 'x-default', href: 'https://www.hypernode.com/en/plans-and-prices/' },
    ],
  }}
>
  <PricingPage />
</BaseLayout>
