---
import { getEntry } from 'astro:content'
import Homepage from '../../components/pages-view/homepage/Homepage.astro'
import BaseLayout from '../../layouts/BaseLayout.astro'

const entry = await getEntry('homepage', 'content')

if (!entry) {
  throw new Error('Homepage content entry not found: src/content/homepage/content.mdx')
}

const { seo } = entry.data
---

<BaseLayout
  seo={{
    title: seo.title,
    description: seo.description,
    canonical: 'https://www.hypernode.com/en/',
    ogImage: 'https://www.hypernode.com/wp-content/uploads/2023/09/Hypernode-OG-image.jpg',
    hreflang: [
      { lang: 'en', href: 'https://www.hypernode.com/en/' },
      { lang: 'nl', href: 'https://www.hypernode.com/nl/' },
      { lang: 'x-default', href: 'https://www.hypernode.com/en/' },
    ],
  }}
>
  <Homepage entry={entry} />
</BaseLayout>
