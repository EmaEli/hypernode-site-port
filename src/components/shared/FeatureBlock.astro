---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'
import Button from '../ui/Button.astro'

export interface FeatureBlockCTA {
  label: string
  href: string
}

export interface FeatureBlockProps {
  image: ImageMetadata
  imageAlt: string
  eyebrow?: string
  title: string
  body?: string
  cta?: FeatureBlockCTA
  imagePosition?: 'left' | 'right'
  variant?: 'light' | 'dark'
}

type Props = FeatureBlockProps

const {
  image,
  imageAlt,
  eyebrow,
  title,
  body,
  cta,
  imagePosition = 'right',
  variant = 'light',
} = Astro.props

const EYEBROW_CLASS = 'text-sm font-semibold uppercase tracking-wider text-brand-orange mb-3'
const sectionClass = variant === 'dark' ? 'bg-brand-blue text-white' : 'bg-white text-brand-blue'
const bodyTextClass = variant === 'dark' ? 'text-gray-300' : 'text-gray-600'
const rowClass = imagePosition === 'left' ? 'md:flex-row-reverse' : 'md:flex-row'
---

<section class={`py-16 md:py-24 ${sectionClass}`}>
  <div class={`max-w-7xl mx-auto px-4 flex flex-col ${rowClass} items-center gap-12`}>

    <div class="flex-1">
      {eyebrow && (
        <p class={EYEBROW_CLASS}>{eyebrow}</p>
      )}

      <h2 class="text-3xl md:text-4xl font-bold mb-4">{title}</h2>

      {body && <p class={`text-lg mb-6 ${bodyTextClass}`}>{body}</p>}

      {cta && (
        <Button href={cta.href} variant="primary">{cta.label}</Button>
      )}
    </div>

    <div class="flex-1 flex justify-center">
      <Image src={image} alt={imageAlt} class="max-w-full h-auto" />
    </div>

  </div>
</section>
