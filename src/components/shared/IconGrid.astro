---
import Icon from '../ui/Icon.astro'

export interface IconGridItem {
  icon: string
  title: string
  body: string
}

export interface IconGridProps {
  title?: string
  items: IconGridItem[]
  columns?: 3 | 6
}

type Props = IconGridProps

const { title, items, columns = 3 } = Astro.props

const GRID_CLASS: Record<NonNullable<IconGridProps['columns']>, string> = {
  3: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3',
  6: 'grid-cols-2 sm:grid-cols-3 lg:grid-cols-6',
}

const gridClass = GRID_CLASS[columns]
---

<section class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4">
    {title && (
      <h2 class="text-3xl md:text-4xl font-bold text-brand-blue text-center mb-12">{title}</h2>
    )}

    <ul class={`grid ${gridClass} gap-8 list-none p-0`}>
      {items.map(item => (
        <li class="flex flex-col items-start gap-3">
          <Icon name={item.icon} size={32} />
          <h3 class="font-semibold text-brand-blue">{item.title}</h3>
          <p class="text-gray-600 text-sm">{item.body}</p>
        </li>
      ))}
    </ul>
  </div>
</section>
