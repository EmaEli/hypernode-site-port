---
import Button from '../../ui/primitives/Button'
import CheckboxField from '../../ui/primitives/CheckboxField.astro'
import FormField from '../../ui/primitives/FormField.astro'
import Grid from '../../ui/primitives/Grid.astro'
import HorizontalFlex from '../../ui/primitives/HorizontalFlex.astro'
import VerticalFlex from '../../ui/primitives/VerticalFlex.astro'

export interface HomepageLeadFormProps {
  submitLabel: string
  newsHref: string
  privacyPolicyHref: string
}

type Props = HomepageLeadFormProps

const { submitLabel, newsHref, privacyPolicyHref } = Astro.props
---

<form method="post" action="/api/leads" id="homepage-lead-form" novalidate>
  <Grid mdCols={2} gap="5">
    <FormField id="firstname" placeholder="Your first name" autocomplete="given-name" required errorMessage="First name is required" />
    <FormField id="lastname" placeholder="Your last name" autocomplete="family-name" required errorMessage="Last name is required" />

    <FormField id="company" placeholder="Your company name" autocomplete="organization" />
    <FormField id="website" placeholder="Your website URL" inputmode="url" />

    <FormField id="phone" placeholder="Your phone number" type="tel" inputmode="tel" autocomplete="tel" />
    <FormField id="email" placeholder="Your email" type="email" inputmode="email" autocomplete="email" required errorMessage="Valid email address is required" />

    <div class="md:col-span-2">
      <FormField id="leave_us_a_message" placeholder="Leave us a message" required errorMessage="Message is required" />
    </div>
  </Grid>

    <VerticalFlex gap="4" class="my-4">
      <CheckboxField id="consent-news" name="LEGAL_CONSENT.subscription_type_36279934">
        Yes, keep me informed about <a href={newsHref} target="_blank" rel="noopener">Hypernode news and updates</a>.
      </CheckboxField>

      <CheckboxField id="consent-privacy" name="LEGAL_CONSENT.subscription_type_20878176" required errorMessage="Privacy policy consent is required">
        Yes, I have read the <a href={privacyPolicyHref} target="_blank" rel="noopener">Privacy Policy</a> and give consent to Hypernode.com to store my submitted information.
      </CheckboxField>
    </VerticalFlex>

    <HorizontalFlex justify="center">
      <Button type="submit" size="large">
        {submitLabel}
      </Button>
    </HorizontalFlex>
</form>

<script>
  const form = document.getElementById('homepage-lead-form') as HTMLFormElement
  const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]')!
  const originalLabel = submitBtn.textContent

  const isValidEmail = (v: string) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v)

  function setFieldError(id: string, invalid: boolean) {
    const input = form.querySelector(`#${id}`)
    const error = form.querySelector(`#${id}-error`)
    if (invalid) {
      input?.setAttribute('aria-invalid', 'true')
      error?.classList.remove('hidden')
    } else {
      input?.removeAttribute('aria-invalid')
      error?.classList.add('hidden')
    }
  }

  function validate() {
    const first = (form.querySelector<HTMLInputElement>('#firstname')?.value ?? '').trim()
    const last = (form.querySelector<HTMLInputElement>('#lastname')?.value ?? '').trim()
    const email = (form.querySelector<HTMLInputElement>('#email')?.value ?? '').trim()
    const message = (form.querySelector<HTMLInputElement>('#leave_us_a_message')?.value ?? '').trim()
    const privacy = form.querySelector<HTMLInputElement>('#consent-privacy')?.checked ?? false

    setFieldError('firstname', !first)
    setFieldError('lastname', !last)
    setFieldError('email', !isValidEmail(email))
    setFieldError('leave_us_a_message', !message)
    setFieldError('consent-privacy', !privacy)

    return Boolean(first && last && isValidEmail(email) && message && privacy)
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault()

    if (!validate()) {
      form.querySelector<HTMLElement>('[aria-invalid="true"]')?.focus()
      return
    }

    submitBtn.disabled = true
    submitBtn.textContent = 'Sending…'

    try {
      const res = await fetch(form.action, { method: 'POST', body: new FormData(form) })
      const data = (await res.json()) as { success?: boolean; error?: string }

      if (res.ok && data.success) {
        form.reset()
        submitBtn.textContent = "Message sent. We'll be in touch."
        submitBtn.classList.add('bg-green-500', 'hover:bg-green-600')
      } else {
        submitBtn.textContent = data.error ?? 'Something went wrong'
        submitBtn.classList.add('bg-red-500')
      }
    } catch {
      submitBtn.textContent = 'Error sending message'
      submitBtn.classList.add('bg-red-500')
    } finally {
      setTimeout(() => {
        submitBtn.textContent = originalLabel
        submitBtn.disabled = false
        submitBtn.classList.remove('bg-green-500', 'hover:bg-green-600', 'bg-red-500')
      }, 3000)
    }
  })
</script>
