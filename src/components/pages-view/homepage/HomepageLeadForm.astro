---
import Button from '../../ui/primitives/Button.astro'

export interface HomepageLeadFormProps {
  submitLabel: string
  newsHref: string
  privacyPolicyHref: string
}

type Props = HomepageLeadFormProps

const { submitLabel, newsHref, privacyPolicyHref } = Astro.props

const inputClass =
  'w-full rounded-2xl border border-white/25 bg-white px-4 py-3 text-brand-blue outline-none transition focus:border-brand-sky focus:ring-2 focus:ring-brand-sky/40'
const checkboxClass =
  'mt-1 h-5 w-5 shrink-0 rounded border border-white/20 bg-white text-brand-orange focus:ring-2 focus:ring-brand-sky/40'
---

<form method="post" action="/api/leads" id="homepage-lead-form">
  <fieldset class="grid gap-5 md:grid-cols-2">
    <input
      id="firstname"
      name="firstname"
      required
      placeholder="Your first name"
      type="text"
      class={inputClass}
      inputmode="text"
      autocomplete="given-name"
    />

    <input
      id="lastname"
      name="lastname"
      required
      placeholder="Your last name"
      type="text"
      class={inputClass}
      inputmode="text"
      autocomplete="family-name"
    />
  </fieldset>

  <fieldset class="mt-5 grid gap-5 md:grid-cols-2">
    <input
      id="company"
      name="company"
      placeholder="Your company name"
      type="text"
      class={inputClass}
      inputmode="text"
      autocomplete="organization"
    />

    <input
      id="website"
      name="website"
      placeholder="Your website URL"
      type="text"
      class={inputClass}
      inputmode="url"
    />
  </fieldset>

  <fieldset class="mt-5 grid gap-5 md:grid-cols-2">
    <input
      id="phone"
      name="phone"
      placeholder="Your phone number"
      type="tel"
      class={inputClass}
      inputmode="tel"
      autocomplete="tel"
    />

    <input
      id="email"
      name="email"
      required
      placeholder="Your email"
      type="email"
      class={inputClass}
      inputmode="email"
      autocomplete="email"
    />
  </fieldset>

  <fieldset class="mt-5">
    <input
      id="leave_us_a_message"
      name="leave_us_a_message"
      placeholder="Leave us a message"
      type="text"
      class={inputClass}
      inputmode="text"
    />
  </fieldset>

  <fieldset class="mt-5 space-y-4 text-left text-sm text-white/85">
    <label for="consent-news" class="flex items-start gap-3 text-white">
      <input
        id="consent-news"
        class={checkboxClass}
        type="checkbox"
        name="LEGAL_CONSENT.subscription_type_36279934"
        value="true"
      />
      <span
        >Yes, keep me informed about <a
          href={newsHref}
          target="_blank"
          rel="noopener">Hypernode news and updates</a
        >.</span
      >
    </label>

    <label for="consent-privacy" class="flex items-start gap-3 text-white">
      <input
        id="consent-privacy"
        class={checkboxClass}
        type="checkbox"
        name="LEGAL_CONSENT.subscription_type_20878176"
        value="true"
        required
      />
      <span
        >Yes, I have read the <a
          href={privacyPolicyHref}
          target="_blank"
          rel="noopener">Privacy Policy</a
        > and give consent to Hypernode.com to store my submitted information.</span
      >
    </label>
  </fieldset>

  <div class="mt-8 flex justify-center">
    <Button type="submit" size="large">
      {submitLabel}
    </Button>
  </div>
</form>

<script>
  const form = document.getElementById(
    'homepage-lead-form',
  ) as HTMLFormElement | null
  if (!form) throw new Error('Lead form not found')

  form.addEventListener('submit', async (event) => {
    event.preventDefault()

    const submitButton = form.querySelector(
      'button[type="submit"]',
    ) as HTMLButtonElement | null
    if (!submitButton) return

    // Disable button and show loading state
    submitButton.disabled = true
    const originalText = submitButton.textContent
    submitButton.textContent = 'Sending...'

    try {
      const formData = new FormData(form)
      const response = await fetch(form.action, {
        method: 'POST',
        body: formData,
      })

      const result = (await response.json()) as {
        success?: boolean
        error?: string
        errors?: string[]
      }

      if (response.ok && result.success) {
        // Success — reset form
        form.reset()
        submitButton.textContent = "Message sent. We'll be in touch."
        submitButton.classList.add('bg-green-500', 'hover:bg-green-600')
        setTimeout(() => {
          submitButton.textContent = originalText
          submitButton.classList.remove('bg-green-500', 'hover:bg-green-600')
          submitButton.disabled = false
        }, 3000)
      } else {
        // Error
        const errorMessage =
          result.error || result.errors?.[0] || 'Something went wrong'
        submitButton.textContent = `Error: ${errorMessage}`
        submitButton.classList.add('bg-red-500')
        setTimeout(() => {
          submitButton.textContent = originalText
          submitButton.classList.remove('bg-red-500')
          submitButton.disabled = false
        }, 3000)
      }
    } catch (error) {
      console.error('Form submission error:', error)
      submitButton.textContent = 'Error sending message'
      submitButton.classList.add('bg-red-500')
      setTimeout(() => {
        submitButton.textContent = originalText
        submitButton.classList.remove('bg-red-500')
        submitButton.disabled = false
      }, 3000)
    }
  })
</script>
