---
import { getEntry } from 'astro:content'
import FeatureBlock from '../../ui/blocks/FeatureBlock.astro'
import CompanyLogoStrip from '../../ui/blocks/CompanyLogoStrip.astro'
import FormSection from '../../ui/blocks/FormSection.astro'
import HeroImage from '../../ui/blocks/HeroImage.astro'
import IconGridSection from '../../ui/blocks/IconGridSection.astro'
import TestimonialsSection from '../../ui/blocks/TestimonialsSection.astro'
import HomepageLeadForm from './HomepageLeadForm.astro'
import {
  HOMEPAGE_COMPANY_LOGO_BY_KEY,
  HOMEPAGE_IMAGE_BY_KEY,
  HOMEPAGE_TESTIMONIAL_ASSETS,
} from './homepageMediaMaps'

const homepageEntry = await getEntry('homepage', 'content')

if (!homepageEntry) {
  throw new Error('Homepage content entry not found: src/content/homepage/content.mdx')
}

const {
  heroContent,
  featureSectionsIntro,
  featureSectionsHostingTypes,
  featureSectionsGreen,
  featureSectionsTrust,
  reliabilityItems,
  platformItems,
  companyLogos: companyLogoItems,
  testimonials: testimonialItems,
  contactSection,
  moreFeaturesCta,
} = homepageEntry.data

const introSections = featureSectionsIntro.map(section => ({
  ...section,
  image: HOMEPAGE_IMAGE_BY_KEY[section.imageKey],
}))

const hostingTypeSections = featureSectionsHostingTypes.map(section => ({
  ...section,
  image: HOMEPAGE_IMAGE_BY_KEY[section.imageKey],
}))

const greenSections = featureSectionsGreen.map(section => ({
  ...section,
  image: HOMEPAGE_IMAGE_BY_KEY[section.imageKey],
}))

const trustSections = featureSectionsTrust.map(section => ({
  ...section,
  image: HOMEPAGE_IMAGE_BY_KEY[section.imageKey],
}))

const reliabilityGridItems = reliabilityItems.map(item => ({
  ...item,
  image: HOMEPAGE_IMAGE_BY_KEY[item.imageKey],
}))

const platformGridItems = platformItems.map(item => ({
  ...item,
  image: HOMEPAGE_IMAGE_BY_KEY[item.imageKey],
}))

const companyLogos = companyLogoItems.map(item => ({
  image: HOMEPAGE_COMPANY_LOGO_BY_KEY[item.imageKey],
  alt: item.alt,
}))

const testimonials = testimonialItems.map(item => ({
  quote: item.quote,
  author: item.author,
  role: item.role,
  logo: HOMEPAGE_TESTIMONIAL_ASSETS.logos[item.logoKey],
  logoAlt: item.logoAlt,
  photo: HOMEPAGE_TESTIMONIAL_ASSETS.photos[item.photoKey],
  photoAlt: item.photoAlt,
}))
---

<main>
  <HeroImage
    title={heroContent.title}
    subtitle={heroContent.subtitle}
    primaryCta={heroContent.primaryCta}
    secondaryCta={heroContent.secondaryCta}
    videoSrc="https://www.hypernode.com/wp-content/uploads/2023/09/servers.webm"
  />

  {introSections.map(section => (
    <FeatureBlock
      image={section.image}
      imageAlt={section.imageAlt}
      tagline={section.tagline}
      title={section.title}
      body={section.body}
      cta={section.cta}
      imagePosition={section.imagePosition}
      variant={section.variant}
    />
  ))}

  <IconGridSection
    title="Reliability, transparency & next-level support"
    subtitle="Find out what you can expect from our managed hosting."
    items={reliabilityGridItems}
    columns={6}
    cardStyle="styled"
  />

  <CompanyLogoStrip logos={companyLogos} />

  {hostingTypeSections.map(section => (
    <FeatureBlock
      image={section.image}
      imageAlt={section.imageAlt}
      tagline={section.tagline}
      title={section.title}
      body={section.body}
      cta={section.cta}
      imagePosition={section.imagePosition}
      variant={section.variant}
    />
  ))}

  <IconGridSection
    title="More about our managed hosting platform"
    items={platformGridItems}
    columns={3}
    cardStyle="simple"
    cta={moreFeaturesCta}
  />

  {greenSections.map(section => (
    <FeatureBlock
      image={section.image}
      imageAlt={section.imageAlt}
      tagline={section.tagline}
      title={section.title}
      body={section.body}
      cta={section.cta}
      imagePosition={section.imagePosition}
      variant={section.variant}
    />
  ))}

  <TestimonialsSection
    title="Join 2500+ satisfied customers!"
    testimonials={testimonials}
  />

  {trustSections.map(section => (
    <FeatureBlock
      image={section.image}
      imageAlt={section.imageAlt}
      tagline={section.tagline}
      title={section.title}
      body={section.body}
      cta={section.cta}
      imagePosition={section.imagePosition}
      variant={section.variant}
    />
  ))}

  <FormSection
    eyebrow="Get in contact with one of our experts"
    title={contactSection.title}
    subtitle={contactSection.subtitle}
  >
    <HomepageLeadForm
      submitLabel={contactSection.submitLabel}
      newsHref={contactSection.newsHref}
      privacyPolicyHref={contactSection.privacyPolicyHref}
    />
  </FormSection>
</main>