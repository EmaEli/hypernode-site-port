---
import ChangelogFilters from './ChangelogFilters'
import type { ChangelogEntry } from '../../../types/changelog'

export interface ChangelogPageProps {
  entries: ChangelogEntry[]
}

const { entries } = Astro.props
---

<main>
  <section class="layout-container pb-10 pt-16 md:pb-12 md:pt-24">
    <p class="text-sm font-bold uppercase tracking-[0.3em] text-brand-sky">Platform updates</p>
    <div class="mt-4 max-w-4xl">
      <h1>Changelog</h1>
      <p class="mt-6 max-w-3xl text-copy text-brand-blue">
        Explore Hypernode releases by year, category, or keyword. Every entry is loaded at build time and remains available even when the CMS is offline.
      </p>
    </div>
  </section>

  <div class="layout-container">
    <ChangelogFilters client:visible entries={entries} />
  </div>
</main>