---
import ChangelogFilters from './ChangelogFilters'
import PageHero from '../../ui/blocks/PageHero.astro'
import type { ChangelogEntry } from '../../../types/changelog'

export interface ChangelogPageProps {
  entries: ChangelogEntry[]
}

const { entries } = Astro.props
---

<main>
  <PageHero
    eyebrow="Platform updates"
    title="Changelog"
    subtitle="Explore Hypernode releases by year, category, or keyword. Every entry is loaded at build time and remains available even when the CMS is offline."
  />

  <div class="layout-container">
    <ChangelogFilters client:visible entries={entries} />
  </div>
</main>