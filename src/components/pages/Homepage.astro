---
import type { ImageMetadata } from 'astro'
import FeatureBlock from '../ui/blocks/FeatureBlock.astro'
import CompanyLogoStrip from '../ui/blocks/CompanyLogoStrip.astro'
import HomepageLeadForm from './HomepageLeadForm.astro'
import HeroImage from '../ui/blocks/HeroImage.astro'
import IconGridSection from '../ui/blocks/IconGridSection.astro'
import TestimonialsGrid from '../ui/blocks/TestimonialsGrid.astro'
import TestimonialsSection from '../ui/blocks/TestimonialsSection.astro'
import FormSection from '../ui/blocks/FormSection.astro'
import agenciesTrustUs from '../../assets/images/homepage/agencies-trust.svg'
import cloudHosting from '../../assets/images/homepage/cloud-hosting.svg'
import clusterHosting from '../../assets/images/homepage/cluster-hosting.svg'
import controlPanel from '../../assets/images/homepage/control-panel.png'
import dedicatedHosting from '../../assets/images/homepage/dedicated-hosting.svg'
import developersFavourite from '../../assets/images/homepage/developers-favourite.svg'
import enterpriseMonitoring from '../../assets/images/homepage/enterprise-monitoring.svg'
import fasterThanFast from '../../assets/images/homepage/faster-than-fast.svg'
import greenHosting from '../../assets/images/homepage/green-hosting.svg'
import hostingSolutions from '../../assets/images/homepage/hosting-solutions.svg'
import hypernodeInsights from '../../assets/images/homepage/hypernode-insights.webp'
import offeringAllHostingTypes from '../../assets/images/homepage/offering-all-hosting-types.svg'
import relyOnMagento from '../../assets/images/homepage/rely-on-magento.svg'
import scaleWheneverYouWant from '../../assets/images/homepage/scale-whenever-you-want.svg'
import serverUpdates from '../../assets/images/homepage/server-updates.svg'
import support from '../../assets/images/homepage/support.svg'
import worldwideCoverage from '../../assets/images/homepage/worldwide-coverage.svg'
import type { HomepageImageKey } from '../../types/homepage'
import {
  companyLogos,
  contactSection,
  heroContent,
  homepageFeatureSections,
  moreFeaturesCta,
  platformItems,
  reliabilityItems,
  testimonials,
} from '../../content/pages/homepage/content'

const imageByKey: Record<HomepageImageKey, ImageMetadata> = {
  agenciesTrustUs,
  cloudHosting,
  clusterHosting,
  controlPanel,
  dedicatedHosting,
  developersFavourite,
  enterpriseMonitoring,
  fasterThanFast,
  greenHosting,
  hostingSolutions,
  hypernodeInsights,
  offeringAllHostingTypes,
  relyOnMagento,
  scaleWheneverYouWant,
  serverUpdates,
  support,
  worldwideCoverage,
}

const featureSections = homepageFeatureSections.map(section => ({
  ...section,
  image: imageByKey[section.imageKey],
}))

const reliabilityGridItems = reliabilityItems.map(item => ({
  ...item,
  image: imageByKey[item.imageKey],
}))

const platformGridItems = platformItems.map(item => ({
  ...item,
  image: imageByKey[item.imageKey],
}))
---

<main>
  <HeroImage
    title={heroContent.title}
    subtitle={heroContent.subtitle}
    primaryCta={heroContent.primaryCta}
    secondaryCta={heroContent.secondaryCta}
    videoSrc="https://www.hypernode.com/wp-content/uploads/2023/09/servers.webm"
  />

  {featureSections.slice(0, 2).map(section => (
    <FeatureBlock
      image={section.image}
      imageAlt={section.imageAlt}
      tagline={section.tagline}
      title={section.title}
      body={section.body}
      cta={section.cta}
      imagePosition={section.imagePosition}
      variant={section.variant}
    />
  ))}

  <IconGridSection
    title="Reliability, transparency & next-level support"
    subtitle="Find out what you can expect from our managed hosting."
    items={reliabilityGridItems}
    columns={6}
    cardStyle="styled"
  />

  <CompanyLogoStrip logos={companyLogos} />

  {featureSections.slice(2, 5).map(section => (
    <FeatureBlock
      image={section.image}
      imageAlt={section.imageAlt}
      tagline={section.tagline}
      title={section.title}
      body={section.body}
      cta={section.cta}
      imagePosition={section.imagePosition}
      variant={section.variant}
    />
  ))}

  <IconGridSection
    title="More about our managed hosting platform"
    items={platformGridItems}
    columns={3}
    cardStyle="simple"
    cta={moreFeaturesCta}
  />

  {featureSections.slice(5, 6).map(section => (
    <FeatureBlock
      image={section.image}
      imageAlt={section.imageAlt}
      tagline={section.tagline}
      title={section.title}
      body={section.body}
      cta={section.cta}
      imagePosition={section.imagePosition}
      variant={section.variant}
    />
  ))}

  <TestimonialsSection
    title="Join 2500+ satisfied customers!"
    testimonials={testimonials}
  />

  {featureSections.slice(6).map(section => (
    <FeatureBlock
      image={section.image}
      imageAlt={section.imageAlt}
      tagline={section.tagline}
      title={section.title}
      body={section.body}
      cta={section.cta}
      imagePosition={section.imagePosition}
      variant={section.variant}
    />
  ))}

  <FormSection
    eyebrow="Get in contact with one of our experts"
    title={contactSection.title}
    subtitle={contactSection.subtitle}
  >
    <HomepageLeadForm
      submitLabel={contactSection.submitLabel}
      newsHref={contactSection.newsHref}
      privacyPolicyHref={contactSection.privacyPolicyHref}
    />
  </FormSection>
</main>