---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'
import Icon from '../primitives/Icon.astro'
import Section from '../primitives/Section.astro'

export interface IconGridItem {
  icon?: string
  image?: ImageMetadata
  imageAlt?: string
  title: string
  body: string
  href?: string
}

export interface IconGridProps {
  title?: string
  items: IconGridItem[]
  columns?: 3 | 6
  cardStyle?: 'simple' | 'styled'
}

type Props = IconGridProps

const { title, items, columns = 3, cardStyle = 'styled' } = Astro.props

const GRID_CLASS: Record<NonNullable<IconGridProps['columns']>, string> = {
  3: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3',
  6: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3',
}
const gridClass = GRID_CLASS[columns]

const STATIC_CARD_CLASS: Record<NonNullable<IconGridProps['cardStyle']>, string> = {
  simple: 'flex h-full flex-col rounded-panel border border-brand-blue/10 bg-white p-6',
  styled: 'flex h-full flex-col border border-brand-blue/10 bg-white p-6 shadow-panel',
}

const INTERACTIVE_CARD_CLASS: Record<NonNullable<IconGridProps['cardStyle']>, string> = {
  simple:
    'group flex h-full flex-col rounded-panel border border-brand-blue/10 bg-white p-6 focus:outline-2 focus:outline-offset-4 focus:outline-brand-orange',
  styled:
    'group flex h-full flex-col border border-brand-blue/10 bg-white p-6 shadow-panel-strong transition-all duration-200 hover:translate-y-1 hover:shadow-panel-hover focus:outline-2 focus:outline-offset-4 focus:outline-brand-orange',
}

const linkedCardClass = INTERACTIVE_CARD_CLASS[cardStyle]
const staticCardClass = STATIC_CARD_CLASS[cardStyle]
---

<Section class="py-16">
  <div class="max-w-content mx-auto px-4">
    {title && (
      <h2 class="text-brand-blue text-center mb-12">{title}</h2>
    )}

    <ul class={`grid ${gridClass} gap-8 list-reset`}>
      {items.map(item => (
        <li class="h-full">
          {
            item.href ? (
              <a
                href={item.href}
                class={linkedCardClass}
              >
                {item.image ? (
                  <Image src={item.image} alt={item.imageAlt ?? ''} class="mb-5 h-12 w-12 object-contain" />
                ) : item.icon ? (
                  <Icon name={item.icon} size={32} class="mb-5 text-brand-orange" />
                ) : null}

                <h3 class="mb-3 text-left text-brand-blue transition-colors group-hover:text-brand-orange">
                  {item.title}
                </h3>
                <p class="text-sm text-gray-600">{item.body}</p>
              </a>
            ) : (
              <div class={staticCardClass}>
                {item.image ? (
                  <Image src={item.image} alt={item.imageAlt ?? ''} class="mb-5 h-28 w-full object-contain object-left" />
                ) : item.icon ? (
                  <Icon name={item.icon} size={32} class="mb-5 text-brand-orange" />
                ) : null}

                <h3 class="mb-3 text-left text-brand-blue">{item.title}</h3>
                <p class="text-sm text-gray-600">{item.body}</p>
              </div>
            )
          }
        </li>
      ))}
    </ul>
  </div>
</Section>
