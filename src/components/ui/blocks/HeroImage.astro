---
import Button from '../primitives/Button.astro'

export interface HeroImageCta {
  label: string
  href: string
}

export interface HeroImageProps {
  title: string
  subtitle: string
  primaryCta: HeroImageCta
  secondaryCta: HeroImageCta
  videoSrc: string
}

const { title, subtitle, primaryCta, secondaryCta, videoSrc } = Astro.props
---

<section class="relative isolate overflow-hidden bg-brand-blue-dark text-white">
  <video
    class="absolute inset-0 h-full w-full object-cover"
    autoplay
    muted
    loop
    playsinline
    aria-hidden="true"
  >
    <source src={videoSrc} type="video/webm" />
  </video>

  <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(2,24,43,0.28)_0%,rgba(2,24,43,0.62)_45%,rgba(2,24,43,0.82)_100%)]"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(81,179,219,0.22),transparent_42%)]"></div>

  <div class="relative mx-auto flex min-h-[42rem] max-w-content items-center justify-center px-4 py-20 text-center sm:px-6 lg:min-h-[48rem] lg:px-8">
    <div class="max-w-4xl">
      <h1 class="text-white">{title}</h1>
      <p class="mx-auto mt-6 max-w-3xl text-lg leading-8 text-white/82 md:text-xl">{subtitle}</p>

      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <Button href={primaryCta.href} variant="primary">{primaryCta.label}</Button>
        <Button href={secondaryCta.href} variant="secondary">{secondaryCta.label}</Button>
      </div>
    </div>
  </div>
</section>