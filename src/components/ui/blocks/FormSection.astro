---
import Section from '../primitives/Section.astro'

export interface FormSectionProps {
  title: string
  subtitle?: string
  eyebrow?: string
}

type Props = FormSectionProps

const { title, subtitle, eyebrow } = Astro.props
---

<Section spacing="default" bg="bg-[linear-gradient(135deg,#063B67_0%,#074E8A_45%,#51B3DB_140%)]" class="text-white">
  <div class="mx-auto max-w-4xl px-4">
    <div class="text-center">
      {eyebrow && (
        <p class="text-sm font-bold uppercase tracking-[0.24em] text-brand-sky">{eyebrow}</p>
      )}
      <h2 class="mt-4 text-white">{title}</h2>
      {subtitle && <p class="mx-auto mt-5 max-w-2xl text-lg text-white/80">{subtitle}</p>}
    </div>

    <div class="mx-auto mt-10 max-w-3xl">
      <slot />
    </div>
  </div>
</Section>