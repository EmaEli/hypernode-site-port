---
import { Image } from 'astro:assets'
import type { Testimonial } from '../../../types/homepage'
import VerticalFlex from '../primitives/VerticalFlex'

export interface Props {
  testimonials: Testimonial[]
  class?: string
}

const { testimonials, class: className } = Astro.props
const ulClass = ['grid-3-responsive list-reset gap-6', className].filter(Boolean).join(' ')
---

<ul class={ulClass}>
  {testimonials.map(item => (
    <li class="card-testimonial">
      <div class="flex h-12 items-center justify-center">
        <Image
          src={item.logo}
          alt={item.logoAlt}
          height={40}
          class="max-h-10 w-auto object-contain"
        />
      </div>

      <p class="mt-5 flex-1 text-center text-ui-label font-normal leading-relaxed text-white">
        "{item.quote}"
      </p>

      <VerticalFlex align="center" gap="2" className="mt-5">
        <Image
          src={item.photo}
          alt={item.photoAlt}
          width={48}
          height={48}
          class="h-12 w-12 rounded-full object-cover"
        />
        <p class="text-ui-label font-bold text-white">{item.author}</p>
        <p class="text-ui-sm text-white/80">{item.role}</p>
      </VerticalFlex>
    </li>
  ))}
</ul>
