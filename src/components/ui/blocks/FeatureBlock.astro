---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'
import Button from '../primitives/Button.astro'

export interface FeatureBlockCTA {
  label: string
  href: string
}

export interface FeatureBlockProps {
  image: ImageMetadata
  imageAlt: string
  tagline?: string
  title: string
  body?: string | string[]
  cta?: FeatureBlockCTA
  imagePosition?: 'left' | 'right'
  variant?: 'light' | 'dark'
}

type Props = FeatureBlockProps

const {
  image,
  imageAlt,
  tagline,
  title,
  body,
  cta,
  imagePosition = 'right',
  variant = 'light',
} = Astro.props

const TAGLINE_CLASS = 'text-[0.8125rem] font-bold tracking-[3.9px] text-brand-orange'
const sectionClass = variant === 'dark' ? 'bg-brand-blue text-white' : 'bg-white text-brand-blue'
const titleClass = variant === 'dark' ? 'text-white' : 'text-brand-blue'
const bodyTextClass = variant === 'dark' ? 'text-white/80' : 'text-brand-blue'
const rowClass = imagePosition === 'left' ? 'md:flex-row-reverse' : 'md:flex-row'
const bodyItems = Array.isArray(body) ? body : body ? [body] : []
---

<section class={`py-16 md:py-24 ${sectionClass}`}>
  <div class={`max-w-content mx-auto px-4 flex flex-col ${rowClass} items-center gap-12`}>

    <div class="flex-1">
      <h2 class={`text-[43px] leading-[48px] font-bold mb-4 ${titleClass}`}>{title}</h2>

      {tagline && (
        <p class={`${TAGLINE_CLASS} mb-4`}>{tagline}</p>
      )}

      {bodyItems.length > 0 && (
        <div class={`mb-6 space-y-4 text-copy ${bodyTextClass}`}>
          {bodyItems.map(item => (
            <p>{item}</p>
          ))}
        </div>
      )}

      {cta && (
        <Button href={cta.href} variant="primary" size="large">{cta.label}</Button>
      )}
    </div>

    <div class="flex-1 flex justify-center">
      <Image src={image} alt={imageAlt} width={410} height={364} class="max-w-full h-auto" />
    </div>

  </div>
</section>
