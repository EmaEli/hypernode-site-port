---
import { Image } from 'astro:assets'
import type { CompanyLogo } from '../../../types/homepage'

export interface CompanyLogoStripProps {
  logos: CompanyLogo[]
}

type Props = CompanyLogoStripProps

const { logos } = Astro.props
---

<section class="bg-brand-blue-dark py-10">
  <div class="layout-container">
    <div class="grid grid-cols-2 items-center gap-x-6 gap-y-8 sm:grid-cols-3 lg:grid-cols-5">
      {logos.map(logo => (
        <div class="flex items-center justify-center px-3">
          <Image
            src={logo.image}
            alt={logo.alt}
            class="h-9 w-auto max-w-full object-contain md:h-10"
          />
        </div>
      ))}
    </div>
  </div>
</section>