---
export interface CheckboxFieldProps {
  id: string
  name: string
  required?: boolean
  errorMessage?: string
}

type Props = CheckboxFieldProps

const { id, name, required = false, errorMessage } = Astro.props

const CHECKBOX_CLASS =
  'mt-1 h-5 w-5 shrink-0 rounded border border-white/20 bg-white text-brand-orange focus:ring-2 focus:ring-brand-sky/40'
---

<div>
  <label for={id} class="flex items-start gap-3 text-white">
    <input
      {id}
      {name}
      type="checkbox"
      value="true"
      class={CHECKBOX_CLASS}
      aria-required={required ? 'true' : undefined}
      aria-describedby={errorMessage ? `${id}-error` : undefined}
    />
    <span><slot /></span>
  </label>
  {errorMessage && (
    <p id={`${id}-error`} role="alert" class="mt-2 ml-8 text-sm text-red-300 hidden">
      {errorMessage}
    </p>
  )}
</div>
