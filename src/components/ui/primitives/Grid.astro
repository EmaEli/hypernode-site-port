---
import type { FlexGap } from '../../../types/uitypes'

export type GridCols = 1 | 2 | 3 | 4 | 6 | 12

export interface GridProps {
  cols?: GridCols
  smCols?: GridCols
  mdCols?: GridCols
  lgCols?: GridCols
  gap?: FlexGap
  gapX?: FlexGap
  gapY?: FlexGap
  as?: 'div' | 'section' | 'article' | 'ul'
  class?: string
}

const {
  cols,
  smCols,
  mdCols,
  lgCols,
  gap,
  gapX,
  gapY,
  as: Tag = 'div',
  class: className,
} = Astro.props

// Full class strings required so Tailwind's scanner picks them up
const GAP_MAP: Record<NonNullable<FlexGap>, string> = {
  '0': 'gap-0',
  '0.5': 'gap-0.5',
  '1': 'gap-1',
  '1.5': 'gap-1.5',
  '2': 'gap-2',
  '2.5': 'gap-2.5',
  '3': 'gap-3',
  '4': 'gap-4',
  '5': 'gap-5',
  '6': 'gap-6',
  '8': 'gap-8',
  '10': 'gap-10',
  '12': 'gap-12',
  '16': 'gap-16',
}

const GAP_X_MAP: Record<NonNullable<FlexGap>, string> = {
  '0': 'gap-x-0',
  '0.5': 'gap-x-0.5',
  '1': 'gap-x-1',
  '1.5': 'gap-x-1.5',
  '2': 'gap-x-2',
  '2.5': 'gap-x-2.5',
  '3': 'gap-x-3',
  '4': 'gap-x-4',
  '5': 'gap-x-5',
  '6': 'gap-x-6',
  '8': 'gap-x-8',
  '10': 'gap-x-10',
  '12': 'gap-x-12',
  '16': 'gap-x-16',
}

const GAP_Y_MAP: Record<NonNullable<FlexGap>, string> = {
  '0': 'gap-y-0',
  '0.5': 'gap-y-0.5',
  '1': 'gap-y-1',
  '1.5': 'gap-y-1.5',
  '2': 'gap-y-2',
  '2.5': 'gap-y-2.5',
  '3': 'gap-y-3',
  '4': 'gap-y-4',
  '5': 'gap-y-5',
  '6': 'gap-y-6',
  '8': 'gap-y-8',
  '10': 'gap-y-10',
  '12': 'gap-y-12',
  '16': 'gap-y-16',
}

const COLS_MAP: Record<GridCols, string> = {
  1: 'grid-cols-1',
  2: 'grid-cols-2',
  3: 'grid-cols-3',
  4: 'grid-cols-4',
  6: 'grid-cols-6',
  12: 'grid-cols-12',
}

const SM_COLS_MAP: Record<GridCols, string> = {
  1: 'sm:grid-cols-1',
  2: 'sm:grid-cols-2',
  3: 'sm:grid-cols-3',
  4: 'sm:grid-cols-4',
  6: 'sm:grid-cols-6',
  12: 'sm:grid-cols-12',
}

const MD_COLS_MAP: Record<GridCols, string> = {
  1: 'md:grid-cols-1',
  2: 'md:grid-cols-2',
  3: 'md:grid-cols-3',
  4: 'md:grid-cols-4',
  6: 'md:grid-cols-6',
  12: 'md:grid-cols-12',
}

const LG_COLS_MAP: Record<GridCols, string> = {
  1: 'lg:grid-cols-1',
  2: 'lg:grid-cols-2',
  3: 'lg:grid-cols-3',
  4: 'lg:grid-cols-4',
  6: 'lg:grid-cols-6',
  12: 'lg:grid-cols-12',
}

const classes = [
  'grid',
  cols ? COLS_MAP[cols as GridCols] : '',
  smCols ? SM_COLS_MAP[smCols as GridCols] : '',
  mdCols ? MD_COLS_MAP[mdCols as GridCols] : '',
  lgCols ? LG_COLS_MAP[lgCols as GridCols] : '',
  gap ? GAP_MAP[gap as FlexGap] : '',
  !gap && gapX ? GAP_X_MAP[gapX as FlexGap] : '',
  !gap && gapY ? GAP_Y_MAP[gapY as FlexGap] : '',
  className ?? '',
]
  .filter(Boolean)
  .join(' ')
---

<Tag class={classes}>
  <slot />
</Tag>
