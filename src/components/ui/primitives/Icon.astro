---
import { Icon as AstroIcon } from 'astro-icon/components'

export interface IconProps {
  name: string
  size?: 16 | 20 | 24 | 32 | 48
  class?: string
}

type Props = IconProps

const { name, size = 24, class: className } = Astro.props

const SIZE_CLASS: Record<NonNullable<IconProps['size']>, string> = {
  16: 'size-4',
  20: 'size-5',
  24: 'size-6',
  32: 'size-8',
  48: 'size-12',
}

const sizeClass = [SIZE_CLASS[size], className].filter(Boolean).join(' ')
---

<AstroIcon name={name} class={sizeClass} aria-hidden="true" />
