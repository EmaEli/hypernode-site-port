---
import Button from "../../ui/primitives/Button"
import { Icon } from 'astro-icon/components'
import { NAVBAR_LINKS } from "./navbarLinks"
import NavbarMobileDrawer from "./NavbarMobileDrawer"

const NAV_LINK_CLASS =
  'text-gray-700 hover:text-brand-orange transition-colors focus-ring'
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-50">
  <nav
    class="max-w-content mx-auto px-4 flex items-center justify-between h-16"
    aria-label="Main navigation"
  >
    <a
      href="/en/"
      class="font-bold text-brand-blue text-xl focus-ring"
    >
      Hypernode
    </a>

    <ul class="hidden md:flex items-center gap-8 list-none m-0 p-0">
      {NAVBAR_LINKS.map(link => (
        <li class={link.children ? 'relative group' : ''}>
          {link.children ? (
            <>
              <button
                type="button"
                class={`${NAV_LINK_CLASS} flex items-center gap-1`}
                aria-haspopup="true"
              >
                {link.label}
                <Icon name="heroicons:chevron-down" width={16} height={16} aria-hidden="true" class="transition-transform group-hover:rotate-180" />
              </button>
              <ul class="absolute left-0 top-full mt-1 hidden group-hover:flex flex-col w-52 bg-white border border-gray-200 rounded-lg shadow-lg py-1 list-none m-0 p-0 z-50">
                {link.children.map(child => (
                  <li>
                    <a
                      href={child.href}

                      class="block px-4 py-2 text-sm text-gray-700 hover:bg-orange-50 hover:text-brand-orange transition-colors"
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </>
          ) : (
            <a href={link.href} class={NAV_LINK_CLASS}>{link.label}</a>
          )}
        </li>
      ))}
    </ul>

    <div class="hidden md:flex items-center gap-4">
      <Button href="https://www.hypernode.com/en/free-hosting-consult/" variant="primary">
        Free hosting consult
      </Button>
    </div>

    <!-- Mobile hamburger — static placeholder, toggle logic deferred to Milestone 4 -->
    <NavbarMobileDrawer client:load />
  </nav>
</header>
