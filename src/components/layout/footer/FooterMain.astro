---
import { Image } from 'astro:assets'
import logo from "../../../assets/images/hypernode-logo-white.png"
import {
  COLUMN_HEADING_CLASS,
  COLUMN_LIST_CLASS,
  LINK_CLASS,
  SOCIAL_LINK_CLASS,
  footerLinkGroups,
  socialLinks,
} from './footerData'
import Icon from '../../ui/primitives/Icon.astro'
import HorizontalFlex from '../../ui/primitives/HorizontalFlex.astro'
import VerticalFlex from '../../ui/primitives/VerticalFlex'
---

<div class="grid grid-cols-2 gap-8 mb-12 md:grid-cols-3 lg:grid-cols-6">
  <VerticalFlex align="start" gap="6" className="col-span-2 md:col-span-1">
    <a href="/en/" class="inline-block focus:outline-2 focus:outline-offset-2 focus:outline-white">
      <Image src={logo} alt="Hypernode" width={180} height={51} />
    </a>

    <HorizontalFlex align="center" justify="between" class="w-[180px]">
      {socialLinks.map((link) => (
        <a href={link.href} class={SOCIAL_LINK_CLASS} aria-label={link.label}>
          <Icon name={link.title!} size={20} />
        </a>
      ))}
    </HorizontalFlex>
  </VerticalFlex>

  {footerLinkGroups.map((group) => (
    <div>
      <h3 class={COLUMN_HEADING_CLASS}>{group.heading}</h3>
      <ul class={COLUMN_LIST_CLASS}>
        {group.links.map((link) => (
          <li><a href={link.href} class={LINK_CLASS}>{link.label}</a></li>
        ))}
      </ul>
    </div>
  ))}
</div>