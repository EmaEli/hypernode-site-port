---
import Button from '../ui/primitives/Button.astro'

const NAV_LINK_CLASS =
  'text-gray-700 hover:text-brand-orange transition-colors focus:outline-2 focus:outline-offset-2 focus:outline-brand-orange'
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-50">
  <nav
    class="max-w-content mx-auto px-4 flex items-center justify-between h-16"
    aria-label="Main navigation"
  >
    <a
      href="/en/"
      class="font-bold text-brand-blue text-xl focus:outline-2 focus:outline-offset-2 focus:outline-brand-orange"
    >
      Hypernode
    </a>

    <ul class="hidden md:flex items-center gap-8 list-none m-0 p-0">
      <li>
        <a
          href="#"
          class={NAV_LINK_CLASS}
        >Why Hypernode</a>
      </li>

      <li>
        <a
          href="#"
          class={NAV_LINK_CLASS}
        >Products</a>
      </li>

      <li>
        <a
          href="/en/plans-and-prices/"
          class={NAV_LINK_CLASS}
        >Plans &amp; prices</a>
      </li>

      <li>
        <a
          href="https://www.hypernode.com/en/our-partners/"
          class={NAV_LINK_CLASS}
        >Partners</a>
      </li>

      <li>
        <a
          href="https://www.hypernode.com/en/blog/"
          class={NAV_LINK_CLASS}
        >Resources</a>
      </li>
    </ul>

    <div class="hidden md:flex items-center gap-4">
      <Button href="https://www.hypernode.com/en/free-hosting-consult/" variant="primary">
        Free hosting consult
      </Button>
    </div>

    <!-- Mobile hamburger — static placeholder, toggle logic deferred to Milestone 4 -->
    <button
      type="button"
      class="md:hidden p-2 rounded text-gray-700 hover:text-brand-orange focus:outline-2 focus:outline-offset-2 focus:outline-brand-orange"
      aria-label="Open navigation menu"
    >
      <span class="block w-6 h-0.5 bg-current mb-1.5" aria-hidden="true"></span>
      <span class="block w-6 h-0.5 bg-current mb-1.5" aria-hidden="true"></span>
      <span class="block w-6 h-0.5 bg-current" aria-hidden="true"></span>
    </button>
  </nav>
</header>
