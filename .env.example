# Copy this file to .env.local and fill in the values.
# All variables are optional — the build falls back gracefully if they are absent.

# ---------------------------------------------------------------------------
# Strapi CMS (changelog entries)
# Set these to connect to a running Strapi instance at build time.
# Without them, the build uses strapi/seed.json as a fallback.
# See README.md → "Optional: run Strapi" for setup instructions.
# ---------------------------------------------------------------------------
PUBLIC_STRAPI_URL=http://localhost:1337
PUBLIC_STRAPI_TOKEN=your-strapi-api-token-here

# ---------------------------------------------------------------------------
# Lead form forwarding
# Set these to forward homepage form submissions to an external CRM endpoint.
# Without them, submissions are only logged to the console.
# ---------------------------------------------------------------------------
PUBLIC_LEAD_API_URL=https://your-crm-endpoint.example.com/api/leads
PUBLIC_LEAD_API_TOKEN=your-lead-api-token-here
